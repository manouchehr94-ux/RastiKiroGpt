# =============================================================================
# Rasti Service - Environment Variables
# =============================================================================
# Copy this to .env and fill in values.
# NEVER commit .env with real secrets to version control.

# =============================================================================
# DJANGO CORE
# =============================================================================

# Settings module: config.settings.local (dev) or config.settings.production (prod)
DJANGO_SETTINGS_MODULE=config.settings.local

# Secret key — MUST be unique, random, and kept secret in production.
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key

# Debug mode — MUST be False in production.
DEBUG=True

# Allowed hosts — comma-separated. In production: your domain(s).
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF trusted origins — include protocol. In production: https://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# =============================================================================
# DATABASE
# =============================================================================

DB_NAME=rasti_service
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Or use a full DATABASE_URL instead of individual DB_* vars:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# =============================================================================
# PRODUCTION SECURITY (uncomment for production)
# =============================================================================

# DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=True

# =============================================================================
# PAYMENT GATEWAY
# =============================================================================

# Payment expiration timeout (minutes). Pending payments older than this are rejected.
PAYMENT_EXPIRATION_MINUTES=30

# =============================================================================
# NOTES
# =============================================================================
# - In production, use config.settings.production which enforces all security settings.
# - Never use the default SECRET_KEY in production.
# - KYC media files must not be served directly by the web server in production.
# - See docs/PRODUCTION_SECURITY_CHECKLIST.md for full deployment guide.
